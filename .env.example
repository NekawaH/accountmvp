# PostgreSQL connection string
# Free options: Neon (neon.tech), Vercel Postgres, Supabase, Railway
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Generate a strong random string: `openssl rand -hex 32`
JWT_SECRET="replace-with-a-long-random-secret"

# Get your key at resend.com — free tier: 3k emails/month
RESEND_API_KEY="re_xxxxxxxxxxxx"

# "From" address. Must use a verified domain in Resend.
# For testing with Resend's sandbox, use: onboarding@resend.dev
EMAIL_FROM="noreply@yourdomain.com"

# Your deployed URL (no trailing slash). Used in email links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
