generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  emailVerified  Boolean   @default(false)
  verifyToken    String?   @unique
  verifyTokenExp DateTime?
  createdAt      DateTime  @default(now())
}
